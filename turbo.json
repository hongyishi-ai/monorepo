{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["package.json", "pnpm-workspace.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:run": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "@hongyishi/fms#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@hongyishi/fms#dev": { "cache": false, "persistent": true },
    "@hongyishi/heat-stroke#build": {
      "outputs": ["assets/css/tailwind.css"]
    },
    "@hongyishi/heat-stroke#dev": { "cache": false, "persistent": true },
    "@hongyishi/tccc#build": {
      "outputs": ["assets/css/tailwind.css"]
    },
    "@hongyishi/ui#build": {
      "outputs": []
    },
    "@hongyishi/utils#build": {
      "outputs": []
    },
    "@hongyishi/portal#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "out/**", "!build/**"]
    },
    "@hongyishi/portal#dev": { "cache": false, "persistent": true }
  }
}
