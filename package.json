{
  "name": "hongyishi-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:cloudflare": "node scripts/build-cloudflare.mjs",
    "preview:cloudflare": "npx wrangler pages dev .cloudflare/site --compatibility-date=2026-06-16 --install-skills=false",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:static-debt": "node scripts/audit-static-debt.mjs",
    "test:cloudflare": "node --test scripts/build-cloudflare.test.mjs scripts/project-registry.test.mjs scripts/audit-static-debt.test.mjs scripts/cloudflare-config.test.mjs scripts/brand-tokens.test.mjs functions/api/openweather.test.mjs functions/fms/fallback.test.mjs",
    "test:cloudflare-build": "node --test scripts/build-cloudflare.test.mjs",
    "lint": "turbo lint",
    "test": "turbo test:run",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "size:budget": "node scripts/check-size-budget.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "playwright": "^1.54.1",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
